# Copy to .env and fill in. Docker Compose reads `example/.env` automatically
# and substitutes the values into docker-compose.yml at `up` time.

# Required: used by the Editor agent to call Claude Sonnet 4.6.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: URL the browser uses for Jaeger trace links and the "Open Jaeger"
# header link. Defaults to /jaeger/ (reverse-proxy mode on the public demo).
# For local dev with the docker-compose stack, set this to the host-mapped
# Jaeger UI:
# JAEGER_UI_URL=http://localhost:16686
